# PASS Backend Environment

# ---------- 서버 ----------
PORT=3000
NODE_ENV=development

# ---------- DB ----------
DATABASE_URL="file:./dev.db"

# ---------- JWT ----------
JWT_ACCESS_SECRET="change-me-in-production-access-secret-min-32chars"
JWT_REFRESH_SECRET="change-me-in-production-refresh-secret-min-32chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="14d"

# ---------- OTP ----------
OTP_DEMO_CODE="123456"
OTP_TTL_SECONDS=180
OTP_MAX_ATTEMPTS=5

# ---------- PIN ----------
PIN_BCRYPT_ROUNDS=12

# ---------- CORS ----------
CORS_ORIGIN="*"
