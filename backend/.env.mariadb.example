# PASS Backend — MariaDB (Production) Environment Template
# 사용법: cp .env.mariadb.example .env 후 값을 채워 사용

# ---------- 서버 ----------
PORT=3000
NODE_ENV=production

# ---------- MariaDB ----------
# 형식: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://pass_user:strong_pw@localhost:3306/pass_prod"

# Docker compose 사용 시 (호스트=mariadb 컨테이너명)
# DATABASE_URL="mysql://pass_user:strong_pw@mariadb:3306/pass_prod"

# ---------- JWT ----------
JWT_ACCESS_SECRET="replace-me-with-strong-32-char-min-secret-access"
JWT_REFRESH_SECRET="replace-me-with-strong-32-char-min-secret-refresh"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="14d"

# ---------- OTP ----------
# Production에서는 OTP_DEMO_CODE를 제거하거나 빈 값으로 둘 것
# (그래야 서버가 진짜 랜덤 OTP 생성)
OTP_DEMO_CODE=""
OTP_TTL_SECONDS=180
OTP_MAX_ATTEMPTS=5

# ---------- PIN ----------
PIN_BCRYPT_ROUNDS=12

# ---------- CORS ----------
# Production 도메인으로 제한
CORS_ORIGIN="https://pass.chon.ai"
